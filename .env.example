# PostHog product analytics.
# Get the project API key in PostHog → Project Settings → Project API Key.
# The "phc_" prefixed key is safe to expose in the browser bundle.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Region host. Use eu.i.posthog.com for EU Cloud, us.i.posthog.com for US Cloud.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
